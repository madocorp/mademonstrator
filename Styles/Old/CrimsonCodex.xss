/*
  Dark
  Gothic
  cinematic, intense, commanding
*/

Slide {
  font: LiberationSerif-Regular;
  position: absolute;
  width: 100%;
  height: 100%;
  x: 0px;
  y: 0px;
  backgroundColor: #3a2528;
}

Content {
  position: absolute;
  x: 0px;
  y: middle;
  width: 100%;
  padding: 5%h, 6%w;
  color: #fbeaec;
  fontSize: 30px;
  textAlign: center;
}

MainTitle {
  font: LiberationSerif-Bold;
  fontSize: 80px;
  margin: 0px, 0px, 18%h, 0px;
  textAlign: left;
  width: 75%;
  color: #fecaca;
}

Title {
  font: LiberationSerif-Bold;
  fontSize: 52px;
  margin: 36px, 0px;
  padding: 10px, 42px, 4px, 42px;
  textAlign: center;
  width: 100%;
  backgroundColor: #7f1d1d;
  color: #ef8d8d;
}

SubTitle {
  font: LiberationSerif-Bold;
  fontSize: 34px;
  color: #fecaca;
  margin: 1.5%h, 5%;
  width: 90%;
}

Paragraph {
  textAlign: left;
  fontSize: 30px;
  margin: 1.5%h, 5%;
  width: 90%;
}

Block1 {
  width: 49%;
  fontSize: 30px;
  margin: 18px, 0px;
}

Block2 {
  width: 32%;
  fontSize: 30px;
  margin: 18px, 0px;
}

Block3 {
  width: 24%;
  fontSize: 30px;
  margin: 18px, 0px;
}

List {
  width: 90%;
  fontSize: 34px;
  margin: 1.5%h, 5%, 1.5%h, 5%;
}

Bullet {
  fontSize: 50px;
  font: LiberationSerif-Bold;
  padding: 0px, 36px, 0px, 0px;
  ascent: 34px;
}

Code {
  font: LiberationMono-Regular;
  width: 82%;
  margin: 1.5%h, 9%;
  backgroundColor: #3f0d12;
  color: #fecaca;
  padding: 8px, 8px, 4px, 8px;
  fontSize: 28px;
  border: 3px;
  borderColor: #f87171;
}

Quotation {
  font: LiberationSerif-Italic;
  width: 82%;
  margin: 0px, 9%;
  backgroundColor: #2a0a0e;
  padding: 18px, 36px, 12px, 36px;
  fontSize: 34px;
  borderLeft: 4px;
  borderColor: #f87171;
}

Link {
  fontSize: 28px;
  color: #ef4444;
}

LinkId {
  fontSize: 28px;
  color: #fca5a5;
  marginRight: 12px;
}

.emphasized {
  font: LiberationSerif-Bold;
  color: #fde68a;
}

.inlinecode {
  font: LiberationMono-Regular;
  color: #fecaca;
}

